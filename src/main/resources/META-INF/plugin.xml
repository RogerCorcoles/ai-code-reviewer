<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.rogercm.ai-code-reviewer</id>
    <name>AI Code Reviewer</name>
    <vendor url="https://github.com/rogercm/ai-code-reviewer">Roger CM</vendor>

    <description><![CDATA[
        AI-powered code review inside IntelliJ IDEA — without leaving the editor.<br><br>
        Select any code snippet, right-click, and choose <b>Review Code with AI</b>.
        The plugin sends the code to the <b>Groq API</b> (LLaMA 3.3 70B) and displays
        a structured review in a docked tool window, covering:<br>
        <ul>
            <li>Bugs &amp; potential runtime errors</li>
            <li>Code quality and readability</li>
            <li>Performance concerns</li>
            <li>Best practices and design patterns</li>
            <li>Actionable improvement suggestions</li>
        </ul>
        Supports 20+ languages with language-specific review guidance.<br>
        API key is stored securely via the OS keychain — never written to disk in plain text.<br><br>
        Configure at <b>Settings → Tools → AI Code Reviewer</b>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Tool window shown on the right side -->
        <toolWindow
                id="AI Code Review"
                anchor="right"
                secondary="false"
                factoryClass="com.rogercm.aicodereviewer.ui.ReviewToolWindowFactory"
                icon="/icons/toolWindowIcon.svg"/>

        <!-- Persistent settings (model name) -->
        <applicationService
                serviceImplementation="com.rogercm.aicodereviewer.settings.AppSettingsState"/>

        <!-- Project-level service that holds the live tool window reference -->
        <projectService
                serviceImplementation="com.rogercm.aicodereviewer.services.ReviewService"/>

        <!-- Settings page: Settings → Tools → AI Code Reviewer -->
        <applicationConfigurable
                parentId="tools"
                instance="com.rogercm.aicodereviewer.settings.AppSettingsConfigurable"
                id="com.rogercm.aicodereviewer.settings.AppSettingsConfigurable"
                displayName="AI Code Reviewer"/>

    </extensions>

    <actions>
        <action
                id="com.rogercm.aicodereviewer.ReviewCodeAction"
                class="com.rogercm.aicodereviewer.actions.ReviewCodeAction"
                text="Review Code with AI"
                description="Send selected code to Groq AI for a detailed code review">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
